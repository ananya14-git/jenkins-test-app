pipeline {
    agent any
    
    stages {
        stage('Checkout Code') {
            steps {
                echo 'Checking out code from GitHub...'
                git branch: 'main', 
                    url: 'https://github.com/ananya14-git/jenkins-test-app.git'
            }
        }
        
        stage('Build') {
            steps {
                echo 'Building the application...'
                sh 'python3 --version'
                echo 'Build completed!'
            }
        }
        
        stage('Test') {
            steps {
                echo 'Running tests...'
                sh 'python3 test_app.py'
            }
        }
        
        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                sh 'python3 app.py'
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline execution completed!'
        }
        success {
            echo '✅ Pipeline succeeded!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}
